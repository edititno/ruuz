{% comment %} Ruuz — Hidden rainy day collection, shown by JS when weather is rainy {% endcomment %}

<div id="ruuz-rainy" style="display: none;">
  <div style="padding: 48px 20px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-family: var(--font-body--family); font-size: 1.5rem; text-align: center; margin-bottom: 28px;">Rainy Day Essentials</h2>
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;">
      {% assign rainy_collection = collections['rainy-day-essentials'] %}
      {% if rainy_collection %}
        {% for product in rainy_collection.products limit: 4 %}
          <a href="{{ product.url }}" style="text-align: center; text-decoration: none; color: inherit;">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" style="width: 100%; aspect-ratio: 3/4; object-fit: cover; margin-bottom: 8px;">
            {% endif %}
            <h5 style="font-family: var(--font-body--family); font-size: 1.25rem; margin-bottom: 4px;">{{ product.title }}</h5>
            <p style="font-family: var(--font-body--family); font-size: 1rem; color: var(--color-foreground);">{{ product.price | money }}</p>
          </a>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Ruuz Rainy Collection",
  "tag": "section",
  "class": "ruuz-rainy-section",
  "settings": []
}
{% endschema %}
